<script>
        // Simple Micro-interaction: Active link states for tabs
        const navLinks = document.querySelectorAll('nav a');
        navLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                // Not preventing default since they might be real links, just visual feedback
                navLinks.forEach(l => {
                    l.classList.remove('border-b-2', 'border-primary', 'text-primary');
                    l.classList.add('text-on-surface-variant');
                });
                link.classList.add('border-b-2', 'border-primary', 'text-primary');
                link.classList.remove('text-on-surface-variant');
            });
        });

        // Search shortcut feedback
        document.addEventListener('keydown', (e) => {
            if (e.key === '/') {
                e.preventDefault();
                document.querySelector('input[type="text"]').focus();
            }
        });
    </script>
