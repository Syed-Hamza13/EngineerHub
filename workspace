<button class="fixed bottom-margin-desktop right-margin-desktop h-14 w-14 bg-primary text-on-primary rounded-full shadow-lg flex items-center justify-center hover:scale-105 active:scale-95 transition-transform z-50">
<span class="material-symbols-outlined text-[24px]">add</span>
